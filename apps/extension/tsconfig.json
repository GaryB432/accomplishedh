{
  "extends": ["../../tsconfig.base.json"],
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "noUncheckedSideEffectImports": false,
    "noUnusedLocals": false,
    "rootDir": "src",
    "types": ["chrome"],
    "paths": {
      "@environments/*": ["./src/environments/*"]
    }
  },
  "references": [
    { "path": "../../libraries/shared" },
    { "path": "../../libraries/web-ui" }
  ],
  "include": ["./src/**/*"]
}
